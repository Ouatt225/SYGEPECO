# ─── SYGEPECO — Variables d'environnement ─────────────────────────
# Copier ce fichier en .env et remplir les valeurs réelles.
# NE JAMAIS commiter le fichier .env

# ─── Django ────────────────────────────────────────────────────────
# Générer une clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-changez-moi-avant-de-mettre-en-production

# True uniquement en développement local
DEBUG=True

# En production : monsite.com,www.monsite.com
ALLOWED_HOSTS=127.0.0.1,localhost

